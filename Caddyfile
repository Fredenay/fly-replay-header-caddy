{
  auto_https off
  http_port 8080
}

:8080 {
  respond /health-check "OK" 200

  reverse_proxy http://43.249.194.226:20030 {
    # 关键：回源 Host 固定成上游 IP:端口，绕开“域名过白”
    header_up Host {upstream_hostport}

    # 可选：如果机房还看 X-Forwarded-Host，就一起覆盖
    header_up X-Forwarded-Host {upstream_hostport}
  }
}
