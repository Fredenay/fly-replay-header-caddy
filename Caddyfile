{
  auto_https off
  http_port 8080
}

:8080 {
  respond /health-check "OK" 200

  #  以后只改这一行
  reverse_proxy http://103.205.254.57:40702 {
    # 过白绕过：回源 Host 固定成上游 host:port
    header_up Host {upstream_hostport}

    # 让源站生成页面时知道外部域名（给你修复 baseUrl 用）
    header_up X-Forwarded-Host {host}
    header_up X-Forwarded-Proto {scheme}

    # 抗抖动（降低偶发 52x）
    lb_try_duration 5s
    lb_try_interval 250ms

    transport http {
      dial_timeout 5s
      response_header_timeout 30s
      keepalive 30s
    }
  }
}
